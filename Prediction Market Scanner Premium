<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Prediction Market Scanner | Sentiment-Driven Trading Signals</title>
    <meta name="description" content="Real-time sentiment-driven trading signals for Polymarket & Augur. 65% historical accuracy on high-confidence signals.">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #0f132e 100%);
            color: #e0e0e0;
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Header */
        .header {
            text-align: center;
            padding: 40px 20px 20px;
            border-bottom: 1px solid #2a2e4a;
        }

        .header h1 {
            font-size: 2.5rem;
            background: linear-gradient(135deg, #c084fc, #60a5fa);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            margin-bottom: 10px;
        }

        .header p {
            color: #8b8faa;
            max-width: 600px;
            margin: 0 auto;
        }

        /* Stats Bar */
        .stats-bar {
            display: flex;
            justify-content: center;
            gap: 40px;
            flex-wrap: wrap;
            padding: 20px;
            background: rgba(20, 24, 54, 0.6);
            margin: 20px;
            border-radius: 20px;
            backdrop-filter: blur(10px);
        }

        .stat {
            text-align: center;
        }

        .stat-value {
            font-size: 1.8rem;
            font-weight: bold;
            color: #c084fc;
        }

        .stat-label {
            font-size: 0.8rem;
            color: #8b8faa;
        }

        /* Tab Navigation */
        .tab-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .tabs {
            display: flex;
            gap: 10px;
            border-bottom: 1px solid #2a2e4a;
            margin-bottom: 30px;
            flex-wrap: wrap;
        }

        .tab-button {
            background: transparent;
            border: none;
            color: #8b8faa;
            padding: 12px 28px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            border-radius: 8px 8px 0 0;
            font-family: inherit;
        }

        .tab-button:hover {
            color: #c084fc;
            background: rgba(192, 132, 252, 0.1);
        }

        .tab-button.active {
            color: #c084fc;
            border-bottom: 3px solid #c084fc;
            background: rgba(192, 132, 252, 0.05);
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* Shared Styles */
        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 0 20px 0;
        }

        h2 {
            font-size: 1.8rem;
            margin: 1.5rem 0 1rem;
            color: #c084fc;
        }

        h3 {
            font-size: 1.3rem;
            margin: 1rem 0 0.5rem;
            color: #e0e0e0;
        }

        .card {
            background: rgba(20, 24, 54, 0.8);
            backdrop-filter: blur(10px);
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
            border: 1px solid #2a2e4a;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        }

        .badge {
            display: inline-block;
            background: #c084fc20;
            color: #c084fc;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 600;
            margin-right: 8px;
        }

        .price-card {
            background: linear-gradient(135deg, #1a1f3a, #141834);
            border: 1px solid #c084fc40;
            text-align: center;
        }

        .price {
            font-size: 3rem;
            font-weight: 800;
            color: #c084fc;
            margin: 20px 0;
        }

        .price small {
            font-size: 1rem;
            color: #8b8faa;
        }

        .btn {
            display: inline-block;
            background: linear-gradient(135deg, #c084fc, #60a5fa);
            color: white;
            padding: 12px 32px;
            border-radius: 40px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
            font-size: 1rem;
        }

        .btn:hover {
            transform: scale(1.02);
            box-shadow: 0 4px 12px rgba(192, 132, 252, 0.4);
        }

        .btn-outline {
            background: transparent;
            border: 1px solid #c084fc;
            color: #c084fc;
        }

        .btn-outline:hover {
            background: #c084fc20;
        }

        .feature-list {
            list-style: none;
            padding: 0;
            text-align: left;
        }

        .feature-list li {
            padding: 8px 0;
            padding-left: 28px;
            position: relative;
        }

        .feature-list li:before {
            content: "✓";
            color: #22c55e;
            position: absolute;
            left: 0;
            font-weight: bold;
        }

        .disclaimer {
            background: #2a1e3a;
            border-left: 4px solid #c084fc;
            padding: 16px;
            border-radius: 8px;
            font-size: 0.8rem;
            margin-top: 30px;
            color: #aaa;
        }

        .grid-2 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 24px;
        }

        /* Market Table */
        .market-table {
            width: 100%;
            border-collapse: collapse;
        }

        .market-row {
            background: rgba(20, 24, 54, 0.6);
            border-radius: 12px;
            margin-bottom: 12px;
            display: block;
            padding: 16px;
            border: 1px solid #2a2e4a;
        }

        .market-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            margin-bottom: 12px;
        }

        .market-exchange {
            font-size: 0.75rem;
            color: #c084fc;
            background: #c084fc20;
            padding: 2px 8px;
            border-radius: 12px;
        }

        .market-question {
            font-weight: 600;
            font-size: 1rem;
        }

        .market-odds {
            display: flex;
            gap: 16px;
            margin: 12px 0;
        }

        .odds-yes, .odds-no {
            padding: 4px 12px;
            border-radius: 20px;
            font-weight: bold;
        }

        .odds-yes { background: #22c55e20; color: #22c55e; }
        .odds-no { background: #ef444420; color: #ef4444; }

        .signal-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: bold;
        }

        .signal-buy { background: #22c55e20; color: #22c55e; }
        .signal-no-trade { background: #6b728020; color: #9ca3af; }
        .signal-confidence { background: #c084fc20; color: #c084fc; }

        .footer {
            text-align: center;
            padding: 30px;
            border-top: 1px solid #2a2e4a;
            margin-top: 40px;
            font-size: 0.75rem;
            color: #6b7280;
        }

        @media (max-width: 768px) {
            .header h1 { font-size: 1.6rem; }
            .tab-button { padding: 8px 16px; font-size: 0.85rem; }
            .stat-value { font-size: 1.2rem; }
            .stats-bar { gap: 20px; }
        }
    </style>
</head>
