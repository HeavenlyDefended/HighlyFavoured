<script>
    // Market data (simulated - in production, this would fetch from your API)
    const marketsData = [
        { exchange: "Polymarket", question: "Will the Fed cut rates in Q3 2026?", oddsYes: 0.52, oddsNo: 0.48, liquidity: 171000, volume: 20000, redditPosts: 251, sentiment: 0.52, sentimentLabel: "▲ 52%", confidence: 46.88, signal: "NO TRADE", reasoning: "Mixed signals — insufficient edge to trade." },
        { exchange: "Augur", question: "Will BTC exceed $120k by end of 2026?", oddsYes: 0.24, oddsNo: 0.76, liquidity: 474000, volume: 175000, redditPosts: 539, sentiment: 0.51, sentimentLabel: "▲ 51%", confidence: 78.00, signal: "BUY YES", reasoning: "Strong bullish sentiment vs low YES odds — positive mispricing detected." },
        { exchange: "Polymarket", question: "Will the S&P 500 hit 6000 by June 2026?", oddsYes: 0.20, oddsNo: 0.80, liquidity: 281000, volume: 51000, redditPosts: 755, sentiment: 0.69, sentimentLabel: "▲ 69%", confidence: 67.27, signal: "BUY YES", reasoning: "Strong bullish sentiment vs low YES odds — positive mispricing detected." },
        { exchange: "Augur", question: "Will the US enter recession in 2026?", oddsYes: 0.53, oddsNo: 0.47, liquidity: 169000, volume: 6000, redditPosts: 277, sentiment: 0.55, sentimentLabel: "▲ 55%", confidence: 56.60, signal: "NO TRADE", reasoning: "Mixed signals — insufficient edge to trade." },
        { exchange: "Polymarket", question: "Will ETH outperform BTC in Q2 2026?", oddsYes: 0.23, oddsNo: 0.77, liquidity: 30000, volume: 123000, redditPosts: 353, sentiment: 0.39, sentimentLabel: "▲ 39%", confidence: 49.52, signal: "NO TRADE", reasoning: "Mixed signals — insufficient edge to trade." },
        { exchange: "Augur", question: "Will inflation drop below 2% by Dec 2026?", oddsYes: 0.44, oddsNo: 0.56, liquidity: 267000, volume: 27000, redditPosts: 132, sentiment: 0.53, sentimentLabel: "▲ 53%", confidence: 64.75, signal: "BUY YES", reasoning: "Strong bullish sentiment vs low YES odds — positive mispricing detected." },
        { exchange: "Polymarket", question: "Will Apple release AR glasses in 2026?", oddsYes: 0.44, oddsNo: 0.56, liquidity: 238000, volume: 73000, redditPosts: 93, sentiment: 0.21, sentimentLabel: "▲ 21%", confidence: 45.18, signal: "NO TRADE", reasoning: "Mixed signals — insufficient edge to trade." },
        { exchange: "Augur", question: "Will the 2026 midterms flip the Senate?", oddsYes: 0.21, oddsNo: 0.79, liquidity: 32000, volume: 61000, redditPosts: 102, sentiment: 0.29, sentimentLabel: "▲ 29%", confidence: 52.14, signal: "NO TRADE", reasoning: "Mixed signals — insufficient edge to trade." }
    ];

    // Function to render market feed
    function renderMarketFeed() {
        const feedContainer = document.getElementById('marketFeed');
        if (!feedContainer) return;
        
        let html = '';
        marketsData.forEach(market => {
            const signalClass = market.signal === 'BUY YES' ? 'signal-buy' : 'signal-no-trade';
            html += `
                <div class="market-row">
                    <div class="market-header">
                        <span class="market-exchange">${market.exchange}</span>
                        <span class="market-question">${market.question}</span>
                        <span class="badge ${signalClass}">${market.signal}</span>
                    </div>
                    <div class="market-odds">
                        <span class="odds-yes">YES ${(market.oddsYes * 100).toFixed(0)}¢</span>
                        <span class="odds-no">NO ${(market.oddsNo * 100).toFixed(0)}¢</span>
                    </div>
                    <div style="display: flex; flex-wrap: wrap; gap: 16px; font-size: 0.8rem; color: #8b8faa;">
                        <span>💰 Liquidity: $${(market.liquidity / 1000).toFixed(0)}k</span>
                        <span>📊 24h Vol: $${(market.volume / 1000).toFixed(0)}k</span>
                        <span>📝 ${market.redditPosts} Reddit posts</span>
                        <span>${market.sentimentLabel}— ${(market.sentiment * 100).toFixed(0)}% bullish</span>
                    </div>
                    <div style="margin-top: 12px;">
                        <span class="signal-confidence">Signal confidence: ${market.confidence}%</span>
                        <p style="font-size: 0.8rem; margin-top: 8px;">${market.reasoning}</p>
                    </div>
                </div>
            `;
        });
        feedContainer.innerHTML = html;
        
        // Update stats
        const buySignals = marketsData.filter(m => m.signal === 'BUY YES').length;
        document.getElementById('actionableSignals').innerHTML = `${buySignals}/${marketsData.length}`;
    }

    // Tab switching function
    function switchTab(tabId) {
        document.querySelectorAll('.tab-content').forEach(tab => {
            tab.classList.remove('active');
        });
        document.querySelectorAll('.tab-button').forEach(btn => {
            btn.classList.remove('active');
        });
        document.getElementById(tabId).classList.add('active');
        event.target.classList.add('active');
    }

    // Auto-refresh every 30 seconds (simulated)
    let refreshInterval;
    function startAutoRefresh() {
        if (refreshInterval) clearInterval(refreshInterval);
        refreshInterval = setInterval(() => {
            // In production, fetch new data from API
            // For demo, just update timestamp
            const timestamp = new Date().toLocaleTimeString();
            console.log(`Feed refreshed at ${timestamp}`);
        }, 30000);
    }

    // Initialize
    document.addEventListener('DOMContentLoaded', () => {
        renderMarketFeed();
        startAutoRefresh();
        
        // Update timestamp in header
        const timeElement = document.createElement('div');
        timeElement.style.textAlign = 'center';
        timeElement.style.fontSize = '0.7rem';
        timeElement.style.color = '#6b7280';
        timeElement.style.marginTop = '10px';
        timeElement.innerHTML = `Updated ${new Date().toLocaleTimeString()}`;
        document.querySelector('.header').appendChild(timeElement);
        
        setInterval(() => {
            const timeDiv = document.querySelector('.header div:last-child');
            if (timeDiv) {
                timeDiv.innerHTML = `Updated ${new Date().toLocaleTimeString()}`;
            }
        }, 30000);
    });
</script>
